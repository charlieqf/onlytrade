{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["node", "vitest/globals"]
  },
  "include": ["server/**/*.ts", "server/**/*.d.ts", "src/**/*.ts", "src/**/*.d.ts", "src/**/*.tsx", "vite.config.ts"]
}
